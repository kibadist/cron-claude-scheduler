{
  "pollIntervalMinutes": 2,
  "claude": {
    "command": "claude",
    "timeoutMinutes": 60,
    "model": "opus"
  },
  "maxRetries": 1,
  "maxMergeResolves": 1,
  "autonomy": {
    "circuitBreakerThreshold": 3,
    "haltCooldownMinutes": 60,
    "transientCooldownMinutes": 15,
    "maxTransientRetries": 4
  },
  "notifications": {
    "type": "telegram",
    "telegram": {
      "botToken": "123456789:ABCdef_your_bot_token_from_BotFather",
      "chatId": "123456789"
    }
  },
  "statuses": {
    "todo": "Todo",
    "inProgress": "In Progress",
    "inReview": "In Review",
    "done": "Done"
  },
  "projects": [
    {
      "linearProject": "My Web App",
      "path": "/Users/you/Code/my-web-app",
      "gitFlow": "branch-pr",
      "baseBranch": "main",
      "mergeOnVerified": true
    },
    {
      "linearProject": "My Mobile App",
      "path": "/Users/you/Code/my-mobile-app",
      "gitFlow": "branch-push",
      "baseBranch": "main",
      "model": "sonnet"
    }
  ]
}
